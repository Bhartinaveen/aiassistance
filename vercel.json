{
  "version": 2,
  "framework": "nextjs",
  "builds": [
    {
      "src": "scaling-palm-tree/frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "scaling-palm-tree/backend/app/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "scaling-palm-tree/backend/app/main.py"
    },
    {
      "source": "/",
      "destination": "scaling-palm-tree/frontend"
    },
    {
      "source": "/(.*)",
      "destination": "scaling-palm-tree/frontend/$1"
    }
  ]
}
